{
  "uid": "kyra-ai-quality",
  "title": "KYRA AI Quality & Cache",
  "tags": [
    "kyra",
    "ai"
  ],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Quality Score Distribution",
      "type": "histogram",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(kyra_response_quality_score_bucket[5m]))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(kyra_response_quality_score_bucket[5m]))",
          "refId": "B",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 2,
      "title": "Citation Support Ratio",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(kyra_citation_support_ratio_bucket[5m]))",
          "refId": "A",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cache Hit Rate",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(kyra_llm_calls_total)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Injection Detections",
      "type": "timeseries",
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 18,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (category) (rate(kyra_injection_detections_total[5m]))",
          "refId": "A",
          "legendFormat": "{{category}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Sentiment Distribution",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (sentiment) (rate(kyra_sentiment_total[5m]))",
          "refId": "A",
          "legendFormat": "{{sentiment}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "LLM Token Consumption",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (kind) (rate(kyra_llm_tokens_total[5m]))",
          "refId": "A",
          "legendFormat": "{{kind}}"
        }
      ]
    }
  ],
  "id": null
}