{
  "title": "KYRA Compliance & Security",
  "tags": [
    "kyra",
    "compliance"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "PHI Scans (Total)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(kyra_phi_scans_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "PHI Hits (Total)",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(kyra_phi_hits_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Privacy Requests",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(kyra_privacy_requests_total)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "UBA Anomalies",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(kyra_uba_anomalies_total)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "PHI scan rate (by severity)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (severity) (rate(kyra_phi_scans_total[5m]))",
          "refId": "A",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "UBA anomaly rate (by type)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (type) (rate(kyra_uba_anomalies_total[5m]))",
          "refId": "A",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 20,
      "title": "Permission decisions (allow/deny)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (decision) (rate(kyra_permission_decisions_total[5m]))",
          "refId": "A",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 21,
      "title": "Audit entries/sec",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(kyra_audit_entries_total[5m])",
          "refId": "A",
          "legendFormat": "writes/sec"
        }
      ]
    },
    {
      "id": 30,
      "title": "Breach incidents by severity",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum by (severity) (kyra_breach_reported_total)",
          "refId": "A",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 31,
      "title": "Privacy status transitions",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum by (type, status) (kyra_privacy_status_total)",
          "refId": "A",
          "format": "table"
        }
      ]
    }
  ],
  "uid": "kyra-compliance",
  "id": null
}