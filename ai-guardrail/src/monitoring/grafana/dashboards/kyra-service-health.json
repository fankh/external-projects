{
  "title": "KYRA Service Health",
  "tags": [
    "kyra",
    "infra"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Services Up",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(up)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Services Down",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(up == 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "JVM heap used by service",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "expr": "sum by (service) (jvm_memory_used_bytes{area=\"heap\"})",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP 5xx rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP request rate",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_server_requests_seconds_count[5m]))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ],
  "uid": "kyra-service-health",
  "id": null
}