# Anthropic API key for AI drawing generation (leave empty to use the built-in stub)
ANTHROPIC_API_KEY=

# Claude model used for prompt -> drawing generation
ANTHROPIC_MODEL_ID=claude-sonnet-5

# Full path to ODA File Converter executable for DWG -> DXF conversion
# e.g. C:\Program Files\ODA\ODAFileConverter\ODAFileConverter.exe
ODA_FILE_CONVERTER_PATH=
