{
  "name": "kyra-admin-console",
  "version": "1.0.0",
  "description": "KYRA AI Guardrail Admin Console",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "playwright:install": "playwright install",
    "db:sync": "node -e \"require('dotenv').config(); const db = require('./src/config/database'); db.syncDatabase().then(() => { console.log('✓ Database synchronized'); process.exit(0); }).catch(e => { console.error('✗ Sync failed:', e.message); process.exit(1); })\"",
    "db:seed": "node src/scripts/seed-database.js",
    "db:setup": "npm run db:sync && npm run db:seed"
  },
  "keywords": [
    "kyra",
    "admin",
    "console",
    "guardrail"
  ],
  "author": "SeekersLab",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "connect-redis": "^7.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.4",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-github": "^1.1.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "sequelize": "^6.35.2",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
