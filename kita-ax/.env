# Application
NODE_ENV=development
PORT=3005
PROTOCOL=https
HOSTNAME=127.0.0.1

# Session & Redis
SESSION_SECRET=change-this-in-production-very-secret-key
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kyra_admin
DB_USER=kyra
DB_PASSWORD=
DB_SSL=false

# Security
CORS_ORIGINS=https://127.0.0.1,https://localhost
JWT_SECRET=change-this-jwt-secret
COOKIE_DOMAIN=127.0.0.1

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Features
ENABLE_SWAGGER_UI=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
