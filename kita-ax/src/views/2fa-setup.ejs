<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: linear-gradient(135deg, #1a1a40 0%, #2e8b57 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .login-container {
      background: white;
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
      width: 100%;
      max-width: 500px;
      padding: 40px;
    }
    .login-header {
      text-align: center;
      margin-bottom: 30px;
    }
    .login-header h1 {
      font-size: 28px;
      color: #1a1a40;
      margin-bottom: 8px;
    }
    .login-header p {
      color: #666;
      font-size: 14px;
    }
    .setup-steps {
      display: flex;
      gap: 20px;
      margin-bottom: 30px;
    }
    .step {
      flex: 1;
      text-align: center;
    }
    .step-number {
      display: inline-flex;
      width: 40px;
      height: 40px;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: #f5f7fa;
      color: #1a1a40;
      font-weight: 600;
      margin-bottom: 10px;
    }
    .step.active .step-number {
      background: linear-gradient(90deg, #1a1a40 0%, #2e8b57 100%);
      color: white;
    }
    .step-title {
      font-weight: 600;
      color: #1a1a40;
      font-size: 14px;
    }
    .step-subtitle {
      font-size: 12px;
      color: #999;
      margin-top: 4px;
    }
    .form-group {
      margin-bottom: 20px;
    }
    label {
      display: block;
      font-weight: 600;
      color: #1a1a40;
      margin-bottom: 8px;
      font-size: 14px;
    }
    input[type="text"] {
      width: 100%;
      padding: 12px;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 14px;
      transition: all 0.3s;
      font-family: inherit;
    }
    input[type="text"]:focus {
      outline: none;
      border-color: #2e8b57;
      box-shadow: 0 0 0 3px rgba(46, 139, 87, 0.1);
    }
    input#token {
      font-family: 'Courier New', monospace;
      font-size: 18px;
      letter-spacing: 4px;
      text-align: center;
    }
    .qr-code-section {
      text-align: center;
      margin-bottom: 30px;
    }
    .qr-code-section img {
      max-width: 200px;
      width: 100%;
      border: 2px solid #f5f7fa;
      border-radius: 8px;
      padding: 10px;
      background: white;
    }
    .manual-entry {
      background: #f5f7fa;
      padding: 15px;
      border-radius: 6px;
      margin-bottom: 20px;
    }
    .manual-entry p {
      font-size: 12px;
      color: #666;
      margin-bottom: 8px;
    }
    .manual-entry code {
      display: block;
      background: white;
      padding: 10px;
      border-radius: 4px;
      font-family: 'Courier New', monospace;
      font-size: 14px;
      color: #1a1a40;
      word-break: break-all;
      border: 1px solid #ddd;
      text-align: center;
      letter-spacing: 2px;
    }
    .form-actions {
      margin-top: 30px;
    }
    button[type="submit"] {
      width: 100%;
      padding: 12px;
      background: linear-gradient(90deg, #1a1a40 0%, #2e8b57 100%);
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }
    button[type="submit"]:hover {
      box-shadow: 0 4px 12px rgba(46, 139, 87, 0.3);
      transform: translateY(-2px);
    }
    button[type="submit"]:active {
      transform: translateY(0);
    }
    .alert {
      padding: 12px;
      border-radius: 6px;
      margin-bottom: 20px;
      font-size: 14px;
    }
    .alert-error {
      background: #ffebee;
      color: #c62828;
      border-left: 4px solid #d32f2f;
    }
    .info-text {
      background: #f5f7fa;
      padding: 12px;
      border-radius: 6px;
      margin-bottom: 20px;
      font-size: 13px;
      color: #666;
      border-left: 3px solid #2e8b57;
    }
    .backup-codes-note {
      background: #fff3cd;
      padding: 12px;
      border-radius: 6px;
      font-size: 12px;
      color: #856404;
      border-left: 3px solid #ffc107;
      margin-top: 20px;
    }
    .backup-codes-note strong {
      display: block;
      margin-bottom: 8px;
    }
    .back-link {
      text-align: center;
      margin-top: 20px;
    }
    .back-link a {
      color: #2e8b57;
      text-decoration: none;
      font-size: 13px;
    }
    .back-link a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-header">
      <h1>🔐 KYRA</h1>
      <p>Enable Two-Factor Authentication</p>
    </div>

    <% if (locals.error) { %>
    <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="setup-steps">
      <div class="step active">
        <div class="step-number">1</div>
        <div class="step-title">Scan QR Code</div>
        <div class="step-subtitle">With authenticator app</div>
      </div>
      <div class="step">
        <div class="step-number">2</div>
        <div class="step-title">Verify Code</div>
        <div class="step-subtitle">Enter 6-digit code</div>
      </div>
    </div>

    <div class="info-text">
      Scan the QR code below with your authenticator app (Google Authenticator, Authy, Microsoft Authenticator, etc.)
    </div>

    <!-- QR Code -->
    <div class="qr-code-section">
      <img src="<%= qrCodeUrl %>" alt="TOTP QR Code" id="qrCode">
    </div>

    <!-- Manual Entry (if scanning doesn't work) -->
    <div class="manual-entry">
      <p>Can't scan? Enter this key manually:</p>
      <code><%= secret %></code>
    </div>

    <form method="POST" action="/auth/2fa/setup" id="setupForm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="secret" value="<%= secret %>">
      <input type="hidden" name="backupCodes" value="<%= JSON.stringify(backupCodes) %>">

      <div class="form-group">
        <label for="token">Enter 6-digit code from your authenticator app</label>
        <input
          type="text"
          id="token"
          name="token"
          placeholder="000000"
          maxlength="6"
          pattern="\d{6}"
          inputmode="numeric"
          required
          autofocus
        >
      </div>

      <div class="form-actions">
        <button type="submit">Verify & Enable 2FA</button>
      </div>
    </form>

    <div class="backup-codes-note">
      <strong>⚠️ Save Your Backup Codes</strong>
      After verification, you'll receive 8 backup codes. Save them in a secure place. You can use them to regain access if you lose your authenticator device.
    </div>

    <div class="back-link">
      <a href="/admin/settings">← Back to Settings</a>
    </div>
  </div>

  <script>
    // Only allow digits in input
    document.getElementById('token').addEventListener('input', function(e) {
      this.value = this.value.replace(/\D/g, '').substring(0, 6);
    });

    document.getElementById('setupForm').addEventListener('submit', function(e) {
      const token = document.getElementById('token').value;
      if (token.length !== 6) {
        e.preventDefault();
        alert('Please enter a 6-digit code');
      }
    });
  </script>
</body>
</html>
