<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: linear-gradient(135deg, #1a1a40 0%, #2e8b57 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-container {
      background: white;
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
      width: 100%;
      max-width: 400px;
      padding: 40px;
    }
    .login-header {
      text-align: center;
      margin-bottom: 30px;
    }
    .login-header h1 {
      font-size: 28px;
      color: #1a1a40;
      margin-bottom: 8px;
    }
    .login-header p {
      color: #666;
      font-size: 14px;
    }
    .form-group {
      margin-bottom: 20px;
    }
    label {
      display: block;
      font-weight: 600;
      color: #1a1a40;
      margin-bottom: 8px;
      font-size: 14px;
    }
    input[type="text"],
    input[type="number"] {
      width: 100%;
      padding: 12px;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 14px;
      transition: all 0.3s;
      font-family: inherit;
    }
    input[type="text"]:focus,
    input[type="number"]:focus {
      outline: none;
      border-color: #2e8b57;
      box-shadow: 0 0 0 3px rgba(46, 139, 87, 0.1);
    }
    input#token[type="text"] {
      font-family: 'Courier New', monospace;
      font-size: 18px;
      letter-spacing: 4px;
      text-align: center;
    }
    .form-actions {
      margin-top: 30px;
    }
    button[type="submit"] {
      width: 100%;
      padding: 12px;
      background: linear-gradient(90deg, #1a1a40 0%, #2e8b57 100%);
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }
    button[type="submit"]:hover {
      box-shadow: 0 4px 12px rgba(46, 139, 87, 0.3);
      transform: translateY(-2px);
    }
    button[type="submit"]:active {
      transform: translateY(0);
    }
    .alert {
      padding: 12px;
      border-radius: 6px;
      margin-bottom: 20px;
      font-size: 14px;
    }
    .alert-error {
      background: #ffebee;
      color: #c62828;
      border-left: 4px solid #d32f2f;
    }
    .toggle-backup {
      text-align: center;
      margin: 20px 0;
    }
    .toggle-backup button {
      background: none;
      border: none;
      color: #2e8b57;
      cursor: pointer;
      font-size: 13px;
      text-decoration: underline;
      padding: 0;
    }
    .toggle-backup button:hover {
      color: #1a1a40;
    }
    .backup-section {
      display: none;
    }
    .backup-section.active {
      display: block;
    }
    .back-link {
      text-align: center;
      margin-top: 20px;
    }
    .back-link a {
      color: #2e8b57;
      text-decoration: none;
      font-size: 13px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .back-link a:hover {
      text-decoration: underline;
    }
    .info-text {
      background: #f5f7fa;
      padding: 12px;
      border-radius: 6px;
      margin-bottom: 20px;
      font-size: 13px;
      color: #666;
      border-left: 3px solid #2e8b57;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-header">
      <h1>🔐 KYRA</h1>
      <p>Two-Factor Authentication</p>
    </div>

    <% if (locals.error) { %>
    <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="info-text">
      Enter the 6-digit code from your authenticator app.
    </div>

    <form method="POST" action="/auth/2fa/verify" id="twoFactorForm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <!-- TOTP Section (default) -->
      <div class="form-group" id="totpSection">
        <label for="token">Authentication Code</label>
        <input
          type="text"
          id="token"
          name="token"
          placeholder="000000"
          maxlength="6"
          pattern="\d{6}"
          inputmode="numeric"
          required
          autofocus
        >
      </div>

      <!-- Backup Code Section (hidden by default) -->
      <div class="form-group backup-section" id="backupSection">
        <label for="backupToken">Backup Code</label>
        <input
          type="text"
          id="backupToken"
          name="token"
          placeholder="e.g., a3f9c812"
          maxlength="8"
        >
      </div>

      <div class="form-actions">
        <button type="submit">Verify</button>
      </div>
    </form>

    <div class="toggle-backup">
      <button id="toggleButton" onclick="toggleBackupCode(event)">
        Use backup code instead
      </button>
    </div>

    <div class="back-link">
      <form method="POST" action="/logout" style="display: inline;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" style="background: none; border: none; color: #2e8b57; cursor: pointer; text-decoration: none; font-size: 13px;">
          ← Back to Login
        </button>
      </form>
    </div>
  </div>

  <script>
    let useBackupCode = false;

    function toggleBackupCode(e) {
      e.preventDefault();
      useBackupCode = !useBackupCode;
      const totpSection = document.getElementById('totpSection');
      const backupSection = document.getElementById('backupSection');
      const toggleButton = document.getElementById('toggleButton');
      const form = document.getElementById('twoFactorForm');

      if (useBackupCode) {
        totpSection.style.display = 'none';
        backupSection.classList.add('active');
        document.getElementById('backupToken').focus();
        document.getElementById('backupToken').required = true;
        document.getElementById('token').required = false;
        toggleButton.textContent = 'Use authenticator app instead';
      } else {
        totpSection.style.display = 'block';
        backupSection.classList.remove('active');
        document.getElementById('token').focus();
        document.getElementById('token').required = true;
        document.getElementById('backupToken').required = false;
        toggleButton.textContent = 'Use backup code instead';
      }
    }

    // Only allow digits in TOTP input
    document.getElementById('token').addEventListener('input', function(e) {
      this.value = this.value.replace(/\D/g, '').substring(0, 6);
    });
  </script>
</body>
</html>
