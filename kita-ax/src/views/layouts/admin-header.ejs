<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    :root {
      --primary-color: #2e8b57;
      --primary-dark: #1a1a40;
      --secondary-color: #f0f2f5;
      --text-primary: #1a1a40;
      --text-secondary: #666;
      --border-color: #ddd;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f5f7fa;
      color: var(--text-primary);
    }

    .admin-container {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .admin-navbar {
      background: linear-gradient(90deg, var(--primary-dark) 0%, var(--primary-color) 100%);
      color: white;
      padding: 0;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .navbar-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 30px;
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
    }

    .navbar-brand {
      font-size: 18px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .navbar-menu {
      display: flex;
      gap: 20px;
    }

    .nav-link {
      color: rgba(255,255,255,0.8);
      text-decoration: none;
      padding: 8px 12px;
      border-radius: 4px;
      transition: all 0.3s;
      font-size: 14px;
    }

    .nav-link:hover,
    .nav-link.active {
      color: white;
      background: rgba(255,255,255,0.1);
    }

    .navbar-right {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .user-menu {
      display: flex;
      align-items: center;
      gap: 8px;
      position: relative;
    }

    .logout-form {
      display: inline;
      margin: 0;
    }

    .logout-btn {
      background: none;
      border: none;
      color: rgba(255,255,255,0.8);
      cursor: pointer;
      font-size: 14px;
      padding: 0;
      transition: color 0.3s;
    }

    .logout-btn:hover {
      color: white;
    }

    .admin-main {
      flex: 1;
      padding: 30px;
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
    }

    .page-title {
      margin-bottom: 30px;
    }

    .page-title h1 {
      font-size: 28px;
      margin-bottom: 8px;
    }

    .page-title p {
      color: var(--text-secondary);
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <nav class="admin-navbar">
      <div class="navbar-content">
        <div class="navbar-brand">🔐 KYRA</div>
        <div class="navbar-menu">
          <a href="/admin/dashboard" class="nav-link <%= current_page === 'dashboard' ? 'active' : '' %>">Dashboard</a>
          <a href="/admin/users" class="nav-link <%= current_page === 'users' ? 'active' : '' %>">Users</a>
          <a href="/admin/documents" class="nav-link <%= current_page === 'documents' ? 'active' : '' %>">Documents</a>
          <a href="/admin/access-policies" class="nav-link <%= current_page === 'policies' ? 'active' : '' %>">Policies</a>
          <a href="/admin/agents" class="nav-link <%= current_page === 'agents' ? 'active' : '' %>">Agents</a>
          <a href="/admin/audit-logs" class="nav-link <%= current_page === 'audit' ? 'active' : '' %>">Audit</a>
          <a href="/admin/settings" class="nav-link <%= current_page === 'settings' ? 'active' : '' %>">Settings</a>
        </div>
        <div class="navbar-right">
          <div class="user-menu">
            <span style="font-size: 14px;"><%= user.email %></span> |
            <form method="POST" action="/logout" class="logout-form">
              <button type="submit" class="logout-btn">Logout</button>
            </form>
          </div>
        </div>
      </div>
    </nav>

    <main class="admin-main">
