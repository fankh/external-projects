<%- include('../layouts/admin-header') %>

<div class="page-title">
  <h1>Edit Document</h1>
  <p>Update document details</p>
</div>

<% if (flashError) { %>
<div class="flash flash-error" style="margin-bottom:20px;padding:12px 16px;background:#fee;border:1px solid #fcc;border-radius:4px;color:#c33">
  <%= flashError %>
</div>
<% } %>

<div class="admin-panel" style="max-width:500px">
  <form method="POST" action="/admin/documents/<%= editDoc.id %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group" style="margin-bottom:16px;padding:12px;background:#f5f7fa;border-radius:4px">
      <label style="display:block;margin-bottom:4px;font-weight:600;font-size:12px;color:#666">Document ID</label>
      <code style="font-size:12px"><%= editDoc.id %></code>
    </div>

    <div class="form-group" style="margin-bottom:16px">
      <label for="title" style="display:block;margin-bottom:8px;font-weight:600">Document Title</label>
      <input type="text" id="title" name="title" value="<%= editDoc.title %>" required maxlength="255" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px">
    </div>

    <div class="form-group" style="margin-bottom:16px">
      <label for="classification" style="display:block;margin-bottom:8px;font-weight:600">Classification</label>
      <select id="classification" name="classification" required style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px">
        <option value="public" <%= editDoc.classification === 'public' ? 'selected' : '' %>>Public</option>
        <option value="internal" <%= editDoc.classification === 'internal' ? 'selected' : '' %>>Internal</option>
        <option value="confidential" <%= editDoc.classification === 'confidential' ? 'selected' : '' %>>Confidential</option>
        <option value="secret" <%= editDoc.classification === 'secret' ? 'selected' : '' %>>Secret</option>
      </select>
    </div>

    <div class="form-group" style="margin-bottom:16px">
      <label for="owner" style="display:block;margin-bottom:8px;font-weight:600">Owner Email</label>
      <input type="email" id="owner" name="owner" value="<%= editDoc.owner %>" required style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px">
    </div>

    <div class="form-group" style="margin-bottom:16px">
      <label for="description" style="display:block;margin-bottom:8px;font-weight:600">Description</label>
      <textarea id="description" name="description" rows="4" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px;font-family:inherit"><%= editDoc.description || '' %></textarea>
    </div>

    <div style="display:flex;gap:12px;margin-top:24px">
      <button type="submit" class="btn" style="flex:1;padding:10px 16px;background:#2e8b57;color:white;border:none;border-radius:4px;cursor:pointer;font-size:14px;font-weight:600">Update Document</button>
      <a href="/admin/documents" class="btn" style="flex:1;padding:10px 16px;background:#f0f2f5;color:#1a1a40;border:1px solid #ddd;border-radius:4px;text-decoration:none;text-align:center;font-size:14px">Cancel</a>
    </div>
  </form>
</div>

<div class="admin-panel" style="max-width:500px;margin-top:24px">
  <h2 style="margin-bottom:16px;font-size:16px;font-weight:600">File Management</h2>

  <% if (editDoc.filePath && editDoc.fileName) { %>
  <div class="file-info" style="padding:12px 16px;background:#e8f5e9;border:1px solid #c8e6c9;border-radius:4px;margin-bottom:16px">
    <h3 style="margin:0 0 8px 0;font-size:13px;font-weight:600;color:#2e7d32">Current File</h3>
    <p style="margin:4px 0;font-size:13px;color:#1b5e20"><strong>Name:</strong> <%= editDoc.fileName %></p>
    <p style="margin:4px 0;font-size:13px;color:#1b5e20"><strong>Size:</strong> <%= (editDoc.fileSize / 1024 / 1024).toFixed(2) %> MB</p>
    <p style="margin:4px 0;font-size:13px;color:#1b5e20"><strong>Type:</strong> <%= editDoc.fileMimeType %></p>
    <p style="margin:8px 0 0 0;font-size:13px;color:#1b5e20"><strong>Uploaded:</strong> <%= new Date(editDoc.uploadedAt).toLocaleString() %></p>
    <div style="margin-top:12px;display:flex;gap:8px">
      <a href="/admin/documents/<%= editDoc.id %>/download" class="btn" style="padding:8px 12px;background:#1976d2;color:white;border:none;border-radius:4px;text-decoration:none;font-size:13px;cursor:pointer">Download File</a>
    </div>
  </div>
  <% } else { %>
  <p style="color:#666;font-size:13px;margin-bottom:16px">No file uploaded yet. Upload a document file below.</p>
  <% } %>

  <form method="POST" action="/admin/documents/<%= editDoc.id %>/upload" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group" style="margin-bottom:16px">
      <label for="file" style="display:block;margin-bottom:8px;font-weight:600">Select File</label>
      <input type="file" id="file" name="file" required accept=".pdf,.doc,.docx,.xls,.xlsx,.txt,.csv,.json" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px">
      <p style="margin:8px 0 0 0;font-size:12px;color:#666">Allowed types: PDF, Word (DOC/DOCX), Excel (XLS/XLSX), Text, CSV, JSON. Max size: 10 MB</p>
    </div>

    <button type="submit" class="btn" style="width:100%;padding:10px 16px;background:#1976d2;color:white;border:none;border-radius:4px;cursor:pointer;font-size:14px;font-weight:600">Upload File</button>
  </form>
</div>

<%- include('../layouts/admin-footer') %>
