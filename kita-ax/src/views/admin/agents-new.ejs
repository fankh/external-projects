<%- include('../layouts/admin-header') %>

<div class="page-title">
  <h1>Register New Agent</h1>
  <p>Register an AI agent to access the system</p>
</div>

<% if (flashError) { %>
<div class="flash flash-error" style="margin-bottom:20px;padding:12px 16px;background:#fee;border:1px solid #fcc;border-radius:4px;color:#c33">
  <%= flashError %>
</div>
<% } %>

<div class="admin-panel" style="max-width:500px">
  <form method="POST" action="/admin/agents">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group" style="margin-bottom:16px">
      <label for="name" style="display:block;margin-bottom:8px;font-weight:600">Agent Name</label>
      <input type="text" id="name" name="name" required maxlength="100" placeholder="e.g., Content Analyzer" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px">
    </div>

    <div class="form-group" style="margin-bottom:16px">
      <label for="type" style="display:block;margin-bottom:8px;font-weight:600">Agent Type</label>
      <select id="type" name="type" required style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px">
        <option value="">-- Select Type --</option>
        <option value="analysis">Analysis</option>
        <option value="automation">Automation</option>
      </select>
    </div>

    <div class="form-group" style="margin-bottom:24px;padding:12px;background:#f0f8ff;border:1px solid #cce5ff;border-radius:4px">
      <p style="font-size:13px;color:#1a3a5c;margin:0"><strong>ℹ️ Note:</strong> An API key will be automatically generated. You'll see it once after registration — save it securely.</p>
    </div>

    <div style="display:flex;gap:12px;margin-top:24px">
      <button type="submit" class="btn" style="flex:1;padding:10px 16px;background:#2e8b57;color:white;border:none;border-radius:4px;cursor:pointer;font-size:14px;font-weight:600">Register Agent</button>
      <a href="/admin/agents" class="btn" style="flex:1;padding:10px 16px;background:#f0f2f5;color:#1a1a40;border:1px solid #ddd;border-radius:4px;text-decoration:none;text-align:center;font-size:14px">Cancel</a>
    </div>
  </form>
</div>

<%- include('../layouts/admin-footer') %>
