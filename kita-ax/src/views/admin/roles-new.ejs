<%- include('../layouts/admin-header') %>

<div class="page-title">
  <h1>Create New Role</h1>
  <p>Define a new role with permissions</p>
</div>

<% if (flashError) { %>
<div class="flash flash-error" style="margin-bottom:20px;padding:12px 16px;background:#fee;border:1px solid #fcc;border-radius:4px;color:#c33">
  <%= flashError %>
</div>
<% } %>

<div class="admin-panel" style="max-width:500px">
  <form method="POST" action="/admin/access-policies/roles">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group" style="margin-bottom:16px">
      <label for="name" style="display:block;margin-bottom:8px;font-weight:600">Role Name</label>
      <input type="text" id="name" name="name" required maxlength="50" placeholder="e.g., analyst" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px">
    </div>

    <div class="form-group" style="margin-bottom:16px">
      <label for="description" style="display:block;margin-bottom:8px;font-weight:600">Description</label>
      <input type="text" id="description" name="description" required maxlength="500" placeholder="e.g., Data analyst with read access to reports" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px">
    </div>

    <div class="form-group" style="margin-bottom:16px">
      <label for="permissions" style="display:block;margin-bottom:8px;font-weight:600">Permissions</label>
      <textarea id="permissions" name="permissions" placeholder="Comma-separated: read:documents, write:reports, read:policies" rows="4" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px;font-family:monospace"></textarea>
      <small style="color:#666;display:block;margin-top:4px">Enter permissions separated by commas</small>
    </div>

    <div style="display:flex;gap:12px;margin-top:24px">
      <button type="submit" class="btn" style="flex:1;padding:10px 16px;background:#2e8b57;color:white;border:none;border-radius:4px;cursor:pointer;font-size:14px;font-weight:600">Create Role</button>
      <a href="/admin/access-policies?tab=rbac" class="btn" style="flex:1;padding:10px 16px;background:#f0f2f5;color:#1a1a40;border:1px solid #ddd;border-radius:4px;text-decoration:none;text-align:center;font-size:14px">Cancel</a>
    </div>
  </form>
</div>

<%- include('../layouts/admin-footer') %>
